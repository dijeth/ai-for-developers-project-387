{
  "name": "e2e",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test --workers=1",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:external": "playwright test --workers=1",
    "test:external:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "description": "E2E tests using Playwright. Run 'npm run e2e' from root to start services and run tests.",
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dayjs": "^1.11.20"
  }
}
