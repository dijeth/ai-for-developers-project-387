generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Owner (Владелец календаря) - singleton
// ============================================================================

model Owner {
  id                 String   @id @default("owner")
  name               String
  email              String
  description        String?
  avatar             String?
  bookingMonthsAhead Int      @default(3) // 1-12 месяцев

  // WorkingHours встроены в Owner (не отдельная таблица)
  workingHoursStart  String   @default("09:00") // формат HH:MM
  workingHoursEnd    String   @default("17:00") // формат HH:MM
  workingDays        String   @default("[\"mon\",\"tue\",\"wed\",\"thu\",\"fri\"]") // JSON массив DayOfWeek

  // Связь с TimeOff (один-ко-многим)
  timeOffs           TimeOff[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ============================================================================
// TimeOff (Выходные/отпуска)
// ============================================================================

model TimeOff {
  id            String   @id @default(cuid())
  startDateTime DateTime
  endDateTime   DateTime

  // Связь с Owner
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId       String   @default("owner")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startDateTime, endDateTime])
}

// ============================================================================
// EventType (Типы событий - 30 мин, 60 мин, и т.д.)
// ============================================================================

model EventType {
  id              String    @id @default(cuid())
  title           String
  durationMinutes Int       // 15-480 минут

  // Связь с Booking
  bookings        Booking[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================================================
// Booking (Бронирования)
// ============================================================================

model Booking {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime // вычисляется на основе EventType.durationMinutes

  // Guest встроен в Booking (не отдельная таблица)
  guestName   String
  guestEmail  String

  // Связь с EventType (Restrict - запретить удаление EventType при наличии бронирований)
  eventType   EventType @relation(fields: [eventTypeId], references: [id], onDelete: Restrict)
  eventTypeId String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Индекс для быстрого поиска по времени (для проверки пересечений)
  @@index([startTime, endTime])
  @@index([guestEmail])
}
