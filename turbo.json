{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*"],
  "tasks": {
    "tsp:compile": {
      "cache": true,
      "inputs": ["packages/api-spec/**"],
      "outputs": ["packages/contracts/**"]
    },
    "build": {
      "dependsOn": ["^tsp:compile"],
      "cache": true,
      "inputs": ["packages/contracts/**", "apps/**"],
      "outputs": ["dist/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "watch:types": {
      "cache": false,
      "persistent": true,
      "inputs": ["packages/contracts/openapi.yaml"]
    }
  }
}